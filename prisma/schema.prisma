generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String           @id
  email       String           @unique
  name        String
  createdAt   DateTime         @default(now())
  role        Role             @default(SISWA)
  sessions    LatihanSession[]
  sesiTryouts SesiTryout[]

  forumPosts         ForumPost[]
  forumKomentar      ForumKomentar[]
  forumPostLikes     ForumPostLike[]
  forumKomentarLikes ForumKomentarLike[]
}

model Soal {
  id             String          @id @default(uuid())
  pertanyaan     String
  opsi           Json?
  pembahasan     String?
  mapel          String
  tingkat        String
  createdAt      DateTime        @default(now())
  tipe           TipeSoal        @default(SINGLE_CHOICE)
  jawaban        Json
  jawabans       JawabanSiswa[]
  jawabanTryouts JawabanTryout[]
  subtesSoals    SubtesSoal[]
}

model LatihanSession {
  id        String         @id @default(uuid())
  userId    String
  mapel     String
  skor      Int?
  selesai   Boolean        @default(false)
  createdAt DateTime       @default(now())
  jawabans  JawabanSiswa[]
  user      User           @relation(fields: [userId], references: [id])
}

model JawabanSiswa {
  id        String         @id @default(uuid())
  sessionId String
  soalId    String
  benar     Boolean
  jawaban   Json
  session   LatihanSession @relation(fields: [sessionId], references: [id])
  soal      Soal           @relation(fields: [soalId], references: [id])
}

model Tryout {
  id        String         @id @default(uuid())
  judul     String
  deskripsi String?
  status    StatusTryout   @default(DRAFT)
  mulaiAt   DateTime
  selesaiAt DateTime
  durasiTps Int
  durasiTka Int
  createdAt DateTime       @default(now())
  sesi      SesiTryout[]
  subtes    SubtesTryout[]
}

model SubtesTryout {
  id       String       @id @default(uuid())
  tryoutId String
  mapel    String
  urutan   Int
  durasi   Int
  soals    SubtesSoal[]
  tryout   Tryout       @relation(fields: [tryoutId], references: [id])
}

model SubtesSoal {
  id        String       @id @default(uuid())
  subtesId  String
  soalId    String
  nomorSoal Int
  soal      Soal         @relation(fields: [soalId], references: [id])
  subtes    SubtesTryout @relation(fields: [subtesId], references: [id])
}

model SesiTryout {
  id             String           @id @default(uuid())
  tryoutId       String
  userId         String
  status         StatusSesiTryout @default(IN_PROGRESS)
  subtesAktif    String?
  subtesDeadline DateTime?
  skorTps        Int?
  skorTka        Int?
  skorTotal      Int?
  mulaiAt        DateTime         @default(now())
  selesaiAt      DateTime?
  jawabans       JawabanTryout[]
  tryout         Tryout           @relation(fields: [tryoutId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id])
}

model JawabanTryout {
  id      String     @id @default(uuid())
  sesiId  String
  soalId  String
  jawaban Json
  benar   Boolean
  sesi    SesiTryout @relation(fields: [sesiId], references: [id])
  soal    Soal       @relation(fields: [soalId], references: [id])
}

model PTN {
  id          String    @id @default(uuid())
  nama        String
  singkatan   String
  kota        String
  provinsi    String
  akreditasi  String    // "A" | "B" | "Unggul" | "Baik Sekali" | "Baik"
  tipe        String    // "Universitas" | "Institut" | "Politeknik" | "Sekolah Tinggi"
  website     String?
  logoUrl     String?
  deskripsi   String?
  createdAt   DateTime  @default(now())

  jurusans    Jurusan[]
}

model Jurusan {
  id             String   @id @default(uuid())
  ptnId          String
  nama           String
  kode           String
  fakultas       String
  jenjang        String   // "S1" | "D3" | "D4"
  kelompok       String   // "SAINTEK" | "SOSHUM" | "CAMPURAN"
  dayaTampung    Int?
  passingGrade   Float?
  deskripsi      String?
  prospekKerja   String?
  createdAt      DateTime @default(now())

  ptn            PTN @relation(fields: [ptnId], references: [id])
}

enum Role {
  ADMIN
  SISWA
}

enum TipeSoal {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum StatusTryout {
  DRAFT
  PUBLISHED
  ONGOING
  ENDED
}

enum StatusSesiTryout {
  IN_PROGRESS
  SUBMITTED
  EXPIRED
}

model KategoriForumPost {
  id          String   @id @default(uuid())
  nama        String   @unique
  slug        String   @unique  // url-friendly, contoh: "diskusi-soal"
  deskripsi   String?
  createdAt   DateTime @default(now())

  posts       ForumPost[]
}

model ForumPost {
  id          String   @id @default(uuid())
  userId      String
  kategoriId  String
  judul       String
  konten      String
  likeCount   Int      @default(0)
  viewCount   Int      @default(0)
  isPinned    Boolean  @default(false)  // admin bisa pin post
  isLocked    Boolean  @default(false)  // admin bisa lock post (tidak bisa dikomentari)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id])
  kategori    KategoriForumPost @relation(fields: [kategoriId], references: [id])
  komentar    ForumKomentar[]
  likes       ForumPostLike[]
}

model ForumKomentar {
  id          String   @id @default(uuid())
  postId      String
  userId      String
  parentId    String?  // null = komentar level 1, diisi = reply (level 2)
  konten      String
  likeCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post        ForumPost       @relation(fields: [postId], references: [id])
  user        User            @relation(fields: [userId], references: [id])
  parent      ForumKomentar?  @relation("KomentarReplies", fields: [parentId], references: [id])
  replies     ForumKomentar[] @relation("KomentarReplies")
  likes       ForumKomentarLike[]
}

model ForumPostLike {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      ForumPost @relation(fields: [postId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([postId, userId])  // satu user hanya bisa like satu kali per post
}

model ForumKomentarLike {
  id          String   @id @default(uuid())
  komentarId  String
  userId      String
  createdAt   DateTime @default(now())

  komentar    ForumKomentar @relation(fields: [komentarId], references: [id])
  user        User          @relation(fields: [userId], references: [id])

  @@unique([komentarId, userId])  // satu user hanya bisa like satu kali per komentar
}

