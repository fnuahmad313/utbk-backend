generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  SISWA
}

model User {
  id        String           @id
  email     String           @unique
  name      String
  role      Role             @default(SISWA)
  createdAt DateTime         @default(now())
  sessions  LatihanSession[]
}

enum TipeSoal {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

model Soal {
  id         String   @id @default(uuid())
  pertanyaan String
  tipe       TipeSoal @default(SINGLE_CHOICE)
  opsi       Json?
  jawaban    Json
  pembahasan String?
  mapel      String
  tingkat    String
  createdAt  DateTime @default(now())

  jawabans JawabanSiswa[]
}

model LatihanSession {
  id        String         @id @default(uuid())
  userId    String
  mapel     String
  skor      Int?
  selesai   Boolean        @default(false)
  createdAt DateTime       @default(now())
  jawabans  JawabanSiswa[]
  user      User           @relation(fields: [userId], references: [id])
}

model JawabanSiswa {
  id        String         @id @default(uuid())
  sessionId String
  soalId    String
  jawaban   Json
  benar     Boolean
  session   LatihanSession @relation(fields: [sessionId], references: [id])
  soal      Soal           @relation(fields: [soalId], references: [id])
}
