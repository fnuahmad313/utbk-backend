generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String           @id
  email       String           @unique
  name        String
  createdAt   DateTime         @default(now())
  role        Role             @default(SISWA)
  sessions    LatihanSession[]
  sesiTryouts SesiTryout[]
}

model Soal {
  id             String          @id @default(uuid())
  pertanyaan     String
  opsi           Json?
  pembahasan     String?
  mapel          String
  tingkat        String
  createdAt      DateTime        @default(now())
  tipe           TipeSoal        @default(SINGLE_CHOICE)
  jawaban        Json
  jawabans       JawabanSiswa[]
  jawabanTryouts JawabanTryout[]
  subtesSoals    SubtesSoal[]
}

model LatihanSession {
  id        String         @id @default(uuid())
  userId    String
  mapel     String
  skor      Int?
  selesai   Boolean        @default(false)
  createdAt DateTime       @default(now())
  jawabans  JawabanSiswa[]
  user      User           @relation(fields: [userId], references: [id])
}

model JawabanSiswa {
  id        String         @id @default(uuid())
  sessionId String
  soalId    String
  benar     Boolean
  jawaban   Json
  session   LatihanSession @relation(fields: [sessionId], references: [id])
  soal      Soal           @relation(fields: [soalId], references: [id])
}

model Tryout {
  id        String         @id @default(uuid())
  judul     String
  deskripsi String?
  status    StatusTryout   @default(DRAFT)
  mulaiAt   DateTime
  selesaiAt DateTime
  durasiTps Int
  durasiTka Int
  createdAt DateTime       @default(now())
  sesi      SesiTryout[]
  subtes    SubtesTryout[]
}

model SubtesTryout {
  id       String       @id @default(uuid())
  tryoutId String
  mapel    String
  urutan   Int
  durasi   Int
  soals    SubtesSoal[]
  tryout   Tryout       @relation(fields: [tryoutId], references: [id])
}

model SubtesSoal {
  id        String       @id @default(uuid())
  subtesId  String
  soalId    String
  nomorSoal Int
  soal      Soal         @relation(fields: [soalId], references: [id])
  subtes    SubtesTryout @relation(fields: [subtesId], references: [id])
}

model SesiTryout {
  id             String           @id @default(uuid())
  tryoutId       String
  userId         String
  status         StatusSesiTryout @default(IN_PROGRESS)
  subtesAktif    String?
  subtesDeadline DateTime?
  skorTps        Int?
  skorTka        Int?
  skorTotal      Int?
  mulaiAt        DateTime         @default(now())
  selesaiAt      DateTime?
  jawabans       JawabanTryout[]
  tryout         Tryout           @relation(fields: [tryoutId], references: [id])
  user           User             @relation(fields: [userId], references: [id])
}

model JawabanTryout {
  id      String     @id @default(uuid())
  sesiId  String
  soalId  String
  jawaban Json
  benar   Boolean
  sesi    SesiTryout @relation(fields: [sesiId], references: [id])
  soal    Soal       @relation(fields: [soalId], references: [id])
}

enum Role {
  ADMIN
  SISWA
}

enum TipeSoal {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum StatusTryout {
  DRAFT
  PUBLISHED
  ONGOING
  ENDED
}

enum StatusSesiTryout {
  IN_PROGRESS
  SUBMITTED
  EXPIRED
}
