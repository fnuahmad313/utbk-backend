generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  SISWA
}

model User {
  id        String           @id
  email     String           @unique
  name      String
  role      Role             @default(SISWA)
  createdAt DateTime         @default(now())
  sessions  LatihanSession[]
  sesiTryouts   SesiTryout[]
}

enum TipeSoal {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

model Soal {
  id         String   @id @default(uuid())
  pertanyaan String
  tipe       TipeSoal @default(SINGLE_CHOICE)
  opsi       Json?
  jawaban    Json
  pembahasan String?
  mapel      String
  tingkat    String
  createdAt  DateTime @default(now())

  jawabans JawabanSiswa[]
  subtesSoals   SubtesSoal[]
  jawabanTryouts   JawabanTryout[]
}

model LatihanSession {
  id        String         @id @default(uuid())
  userId    String
  mapel     String
  skor      Int?
  selesai   Boolean        @default(false)
  createdAt DateTime       @default(now())
  jawabans  JawabanSiswa[]
  user      User           @relation(fields: [userId], references: [id])
}

model JawabanSiswa {
  id        String         @id @default(uuid())
  sessionId String
  soalId    String
  jawaban   Json
  benar     Boolean
  session   LatihanSession @relation(fields: [sessionId], references: [id])
  soal      Soal           @relation(fields: [soalId], references: [id])
}

enum StatusTryout {
  DRAFT        // dibuat admin, belum dipublish
  PUBLISHED    // bisa dilihat siswa, belum bisa dikerjakan
  ONGOING      // sedang berlangsung, siswa bisa mulai
  ENDED        // waktu habis, tidak bisa dikerjakan lagi
}

enum StatusSesiTryout {
  IN_PROGRESS  // siswa sedang mengerjakan
  SUBMITTED    // siswa submit manual
  EXPIRED      // waktu habis, auto-submit backend
}

model Tryout {
  id            String        @id @default(uuid())
  judul         String
  deskripsi     String?
  status        StatusTryout  @default(DRAFT)
  mulaiAt       DateTime      // jadwal mulai — ditentukan admin
  selesaiAt     DateTime      // jadwal selesai — ditentukan admin
  durasiTps     Int           // durasi subtes TPS dalam menit
  durasiTka     Int           // durasi subtes TKA dalam menit
  createdAt     DateTime      @default(now())

  subtes        SubtesTryout[]
  sesi          SesiTryout[]
}

model SubtesTryout {
  id        String   @id @default(uuid())
  tryoutId  String
  mapel     String   // "TPS" | "TKA_SAINTEK" | "TKA_SOSHUM"
  urutan    Int      // 1 = TPS, 2 = TKA
  durasi    Int      // durasi dalam menit

  tryout    Tryout   @relation(fields: [tryoutId], references: [id])
  soals     SubtesSoal[]
}

model SubtesSoal {
  id          String       @id @default(uuid())
  subtesId    String
  soalId      String
  nomorSoal   Int

  subtes      SubtesTryout @relation(fields: [subtesId], references: [id])
  soal        Soal         @relation(fields: [soalId], references: [id])
}

model SesiTryout {
  id            String             @id @default(uuid())
  tryoutId      String
  userId        String
  status        StatusSesiTryout   @default(IN_PROGRESS)
  subtesAktif   String?            // id SubtesTryout yang sedang dikerjakan
  subtesDeadline DateTime?         // deadline subtes aktif saat ini
  skorTps       Int?
  skorTka       Int?
  skorTotal     Int?
  mulaiAt       DateTime           @default(now())
  selesaiAt     DateTime?

  tryout        Tryout             @relation(fields: [tryoutId], references: [id])
  user          User               @relation(fields: [userId], references: [id])
  jawabans      JawabanTryout[]
}

model JawabanTryout {
  id        String      @id @default(uuid())
  sesiId    String
  soalId    String
  jawaban   Json
  benar     Boolean

  sesi      SesiTryout  @relation(fields: [sesiId], references: [id])
  soal      Soal        @relation(fields: [soalId], references: [id])
}