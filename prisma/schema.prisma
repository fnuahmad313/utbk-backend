generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String           @id
  email     String           @unique
  name      String
  createdAt DateTime         @default(now())
  sessions  LatihanSession[]
}

model Soal {
  id         String         @id @default(uuid())
  pertanyaan String
  opsi       Json
  jawaban    String
  pembahasan String?
  mapel      String
  tingkat    String
  createdAt  DateTime       @default(now())
  jawabans   JawabanSiswa[]
}

model LatihanSession {
  id        String         @id @default(uuid())
  userId    String
  mapel     String
  skor      Int?
  selesai   Boolean        @default(false)
  createdAt DateTime       @default(now())
  jawabans  JawabanSiswa[]
  user      User           @relation(fields: [userId], references: [id])
}

model JawabanSiswa {
  id        String         @id @default(uuid())
  sessionId String
  soalId    String
  jawaban   String
  benar     Boolean
  session   LatihanSession @relation(fields: [sessionId], references: [id])
  soal      Soal           @relation(fields: [soalId], references: [id])
}
